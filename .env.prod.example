# ==========================================
# CONFIGURACION DE PRODUCCION - SISTEMA POS
# Copiar a .env en el VPS y completar valores reales
# ==========================================

POSTGRES_USER=pos_admin_prod
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=pos_db_prod
JWT_SECRET=replace-with-64-char-secret

LOG_SQL=false
ALLOWED_ORIGINS=https://app.tudominio.com,https://tudominio.com

EMAIL_ENABLED=true
EMAIL_API_BASE_URL=https://api.brevo.com/v3/smtp/email
EMAIL_API_TOKEN=replace-with-mail-api-token
EMAIL_API_AUTH_HEADER=api-key
EMAIL_FROM_EMAIL=notificaciones@tudominio.com
EMAIL_FROM_NAME=V1TR0 POS
EMAIL_TIMEOUT_SECONDS=10
FRONTEND_URL=https://app.tudominio.com

LOW_STOCK_THRESHOLD=5
DEFAULT_NOTIFICATION_RECIPIENTS=admin@tudominio.com
PASSWORD_RESET_EXPIRE_MINUTES=30
SCHEDULER_ENABLED=true
DAILY_SUMMARY_HOUR_UTC=23
RUN_MIGRATIONS_ON_STARTUP=false
